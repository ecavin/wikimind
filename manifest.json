{
  "manifest_version": 3,
  "name": "WikiMind",
  "version": "0.1.0",
  "description": "Personal Wikipedia companion: tracks reading history, visualizes article connections, and uses Gemini 3 Flash for recommendations and semantic clustering.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "notifications"
  ],
  "host_permissions": [
    "https://*.wikipedia.org/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.wikipedia.org/wiki/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "WikiMind"
  },
  "options_page": "settings/settings.html",
  "icons": {
    "128": "icons/icon128.png"
  }
}
